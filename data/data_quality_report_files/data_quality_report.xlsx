:\"3LnoOih4wQCBUm1XDSNKDv:override\",\"secondary_exposures\":[],\"id_type\":\"userID\",\"value\":{\"show_context_percentage\":\"1/3\",\"use_new_bottom_pill\":true,\"use_new_scroll\":true},\"is_device_based\":false,\"group_name\":\"Balanced context\",\"is_experiment_active\":false,\"is_user_in_experiment\":false},\"2881703223\":{\"name\":\"2881703223\",\"rule_id\":\"default\",\"secondary_exposures\":[],\"id_type\":\"stableID\",\"value\":{\"prompts\":{\"make_longer\":\"Please make this response longer and more detailed.\",\"simplify\":\"Please simplify this response and make it easier to understand.\",\"landscape_aspect\":\"Please regenerate the image in a landscape (horizontal) aspect ratio.\",\"square_aspect\":\"Please regenerate the image in a square aspect ratio.\",\"make_shorter\":\"Please make this response more concise and brief.\",\"portrait_aspect\":\"Please regenerate the image in a portrait (vertical) aspect ratio.\"}},\"is_device_based\":true,\"passed\":false},\"1097139969\":{\"name\":\"1097139969\",\"rule_id\":\"layerAssignment\",\"secondary_exposures\":[],\"id_type\":\"stableID\",\"value\":{},\"is_device_based\":true,\"is_experiment_active\":true,\"is_user_in_experiment\":false},\"999809785\":{\"name\":\"999809785\",\"rule_id\":\"inlineTargetingRules\",\"secondary_exposures\":[],\"id_type\":\"userID\",\"value\":{},\"is_device_based\":false,\"is_experiment_active\":true,\"is_user_in_experiment\":false},\"2850107578\":{\"name\":\"2850107578\",\"rule_id\":\"7nxmtzMrThjQ6ucoe2XHVB:100.00:19-7nxmty7pqZalN4EsCV24Cz\",\"secondary_exposures\":[],\"id_type\":\"userID\",\"value\":{\"android_large_font_scale_threshold\":1.5,\"ask_chatgpt_system_message\":\"The user is referring to an ad shown to them about: {LABEL}. Your response MUST BE ABOUT THE ADS shown, since the user explicitly asked about them. They are using the 'Ask ChatGPT' feature and you must reply to the user query using the information about the ads, which is:\\n{DATA}\\n\\nFor example: if the user asks 'Tell me more about these' (or other wordings), then your answer should be about details or further information on products, services, locations etc described in the ad and the links in the ad.\",\"android_display_zoom_scale_threshold\":1,\"late_ads_event_discard_timeout_seconds\":5,\"onboarding\":{\"screen_personalization_image_url\":\"https://cdn.openai.com/chatgpt/clients/bazaar/onboarding/personalization_en.png\",\"impression_count\":5,\"screen_trust_image_url\":\"https://cdn.openai.com/chatgpt/clients/bazaar/onboarding/trusted_en.png\",\"screen_privacy_image_url\":\"https://cdn.openai.com/chatgpt/clients/bazaar/onboarding/secure.png\",\"screen_transparency_image_url\":\"https://cdn.openai.com/chatgpt/clients/bazaar/onboarding/controls_en.png\",\"card_image_url\":\"https://cdn.openai.com/chatgpt/clients/onboarding/onboarding-example-1.png\"},\"late_ads_event_discard_timeout_after_message_end_visibility_seconds\":1},\"is_device_based\":false,\"passed\":true},\"1977158438\":{\"name\":\"1977158438\",\"rule_id\":\"default\",\"secondary_exposures\":[],\"id_type\":\"userID\",\"value\":{\"system_prompt\":\"The user is asking about an ad shown to them by {advertiser}. Your response must be about the ad shown. They are using the \\\"Ask ChatGPT\\\" feature to get ChatGPT's honest opinion on the product(s) in the advertisement, and in which situations it could be a great fit for them. You should be honest about when you think the product(s) would vs. would not be useful for the user, based on what you know about them.\\n\\nInformation about the ad:\\n{ad}.\\n\\nStructure your response in the following manner:\\n- Briefly describe the type of user, use case, or situation where this ad/product makes sense for the user.\\n- If appropriate, explain any mismatches with the user's stated preferences or goals. That is, where might it fall short for the user (if appropriate)? You don't have to do this for every query, but feel free to list limitations if you think they're pretty relevant.\\n- Give a concise recommendation (e.g., \\\"worth considering,\\\" \\\"probably not ideal,\\\" \\\"good budget option,\\\" \\\"seriously may be a fit,\\\" etc.)\\n\\nGuidelines:\\n- Be honest and practical.\\n- Do not blindly promote the ad.\\n- Avoid harsh or absolute negative language.\\n- Do not invent details not present in the ad.\\n- Focus on fit, not feature lists.\\n- If the mark on relevance is clearly missed, feel free to be funny with it and keep it lighthearted. Do not mock the user or advertiser; keep the humor gentle.\\n\\nKeep it concise, direct, and easy to scan.\\n\\n{conversation}\",\"enable_web_search\":false,\"user_prompt_key\":\"good_option\"},\"is_device_based\":false,\"passed\":false},\"3487666121\":{\"name\":\"3487666121\",\"rule_id\":\"launchedGroup\",\"secondary_exposures\":[{\"gate\":\"1187522884\",\"gateValue\":\"false\",\"ruleID\":\"default\"},{\"gate\":\"859770335\",\"gateValue\":\"false\",\"ruleID\":\"default\"}],\"id_type\":\"stableID\",\"value\":{\"show_new_pricing_card_ui\":false,\"should_auto_open_pricing_modal_logged_in_with_spinner\":false,\"show_new_pricing_page_general_ui\":false,\"variant\":0},\"is_device_based\":true,\"is_in_layer\":true,\"explicit_parameters\":[\"variant\",\"show_new_pricing_card_ui\",\"show_new_pricing_page_general_ui\"],\"group_name\":\"Control\",\"is_experiment_active\":false,\"is_user_in_experiment\":false},\"619645130\":{\"name\":\"619645130\",\"rule_id\":\"disabled\",\"secondary_exposures\":[],\"id_type\":\"userID\",\"value\":{\"max_days_visible\":-1,\"max_impressions\":-1,\"one_impression_per_day\":false},\"is_device_based\":false,\"passed\":false},\"2076138851\":{\"name\":\"2076138851\",\"rule_id\":\"3QigorHh71tggge0e0kFbD\",\"secondary_exposures\":[],\"id_type\":\"userID\",\"value\":{\"max_concurrency\":20},\"is_device_based\":false,\"group_name\":\"20\",\"is_experiment_active\":true,\"is_user_in_experiment\":true},\"3941338778\":{\"name\":\"3941338778\",\"rule_id\":\"default\",\"secon